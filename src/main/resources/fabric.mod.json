{
	"schemaVersion": 1,
	"id": "lifesteal",
	"version": "${version}",
	"name": "lifesteal",
	"description": "Lifesteal SMP - on PvP kill, killer gains a heart and victim loses one. Reach 0 hearts and get banned; craft or use a Revive Totem to bring players back.",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/lifesteal/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.lifesteal.Lifesteal"
		],
		"client": [
			"com.lifesteal.client.LifestealClient"
		]
	},
	"mixins": [
		"lifesteal.mixins.json",
		{
			"config": "lifesteal.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}